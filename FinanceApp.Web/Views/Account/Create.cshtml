@model FinanceApp.Web.Models.Account

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 p-4" style="border-radius: 20px;">
                <h2 class="fw-bold mb-4">Add New Account</h2>
                
                <form asp-action="Create" method="post">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-semibold">Account Name</label>
                        <input asp-for="Name" class="form-control rounded-pill" placeholder="e.g. Salary Account" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Balance" class="form-label fw-semibold">Starting Balance</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0 rounded-start-pill">$</span>
                            <input asp-for="Balance" type="number" step="0.01" class="form-control border-start-0 rounded-end-pill" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Balance" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary rounded-pill py-2">Create Account</button>
                        <a asp-controller="Expenses" asp-action="Index" class="btn btn-link text-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>